theme = aura
window-theme = system
macos-titlebar-style = tabs
unfocused-split-opacity = 0.6
# font-family = Square Sans Mono
# font-family = Menlo Regular
font-family = Inconsolata Regular Regular

copy-on-select = clipboard
focus-follows-mouse = true
font-thicken = true
# font-feature = -liga
macos-non-native-fullscreen = true
mouse-hide-while-typing = true

# scrollback-limit in bytes, roughly 125,000 lines
scrollback-limit = 100000000

shell-integration = zsh
shell-integration-features = no-cursor
# note: see zsh/.zshrc "ghostty integration"

### Keybindings
# super==cmd, alt==opt
# move between tabs is cmd+alt+arrow
keybind = super+alt+left=previous_tab
keybind = super+alt+right=next_tab
# move between panes is cmd+arrow
keybind = super+left=goto_split:previous
keybind = super+right=goto_split:next
# cmd+s sends :w<enter> - so cmd-s works in vim in terminal
keybind = super+s=text:\x1b:w\n
# Config generated by Ghostty Config

clipboard-read = allow
keybind = super+shift+t=new_tab
# TODO: search scrollback hack

# window-colorspace = srgb
window-colorspace = display-p3
keybind = shift+enter=text:\n

# padding
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

# quick terminal (toggle with cmd+`)
keybind = super+`=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.15

# treat option as alt for terminal keybinds
macos-option-as-alt = true

# click to move cursor at prompt
cursor-click-to-move = true

# clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true

# splits
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# prevent invisible text
minimum-contrast = 1.1

# transparency + blur
background-opacity = 0.92
background-blur = true

# link previews on hover
link-previews = true